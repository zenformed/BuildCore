# --- Supabase (browser + server token verification) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: enables CRM assignee avatars for other org members when not using Core avatar relay only
# SUPABASE_SERVICE_ROLE_KEY=

# CRM document binary storage is delegated to ZenformedCore (private bucket `buildcore-documents` on Core).

# --- SaaS gate (required for this demo app) ---
NEXT_PUBLIC_SAAS_MODE=true

# Public BuildCore app URL (emails, customer portal links, auth redirects).
# Local: http://localhost:3020
# Production: https://buildcore.zenformed.com
BUILDCORE_PUBLIC_APP_URL=http://localhost:3020

# ZenformedPlatform public URL (primary login redirect, sign-out).
# Local: http://localhost:3030
# Production: https://core.zenformed.com
PLATFORM_PUBLIC_APP_URL=http://localhost:3030

# Client-visible Platform URL for browser auth redirects.
# NEXT_PUBLIC_PLATFORM_APP_URL=http://localhost:3030

# Optional client-visible override (auth redirects in browser). Falls back to NEXT_PUBLIC_APP_URL.
# NEXT_PUBLIC_BUILDCORE_APP_URL=http://localhost:3020

# Legacy alias for auth redirects when BUILDCORE_PUBLIC_APP_URL / NEXT_PUBLIC_BUILDCORE_APP_URL unset.
# NEXT_PUBLIC_APP_URL=http://localhost:3020

# --- Optional: mock auth (not used for hosted Core validation) ---
# NEXT_PUBLIC_USE_MOCK_AUTH=true

# --- ZenformedCore HTTP (server-side BFF → Core) ---
ZENFORMED_CORE_API_URL=https://your-zenformed-core.example.com

# --- Entitlement snapshot source for useSaaSProfile (default: core relay) ---
# NEXT_PUBLIC_RUNTIME_ENTITLEMENT_SOURCE=profile

# --- Stripe CTA on license screen (optional) ---
# NEXT_PUBLIC_STRIPE_PAYMENT_URL=https://buy.stripe.com/

# --- CRM data source (default: mock) ---
# NEXT_PUBLIC_CRM_DATA_SOURCE=mock

# --- Electron packaged data dir (production) ---
# DATA_PATH=

# --- Override app slug in Electron main only (defaults to manifest JSON) ---
# ZENFORMED_APP_SLUG=buildcore
